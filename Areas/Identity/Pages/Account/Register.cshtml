@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<h1>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-md-6">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2 class="mb-3">Crea una nueva cuenta</h2>
            <hr />

            <!-- Errores generales -->
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <!-- Nombre -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Nombre" class="form-control" placeholder="Nombre" />
                <label asp-for="Input.Nombre">Nombre</label>
                <span asp-validation-for="Input.Nombre" class="text-danger"></span>
            </div>

            <!-- Apellido -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Apellido" class="form-control" placeholder="Apellido" />
                <label asp-for="Input.Apellido">Apellido</label>
                <span asp-validation-for="Input.Apellido" class="text-danger"></span>
            </div>

            <!-- Correo -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="nombre@ejemplo.com" />
                <label asp-for="Input.Email">Correo electrónico</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- Teléfono -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Telefono" class="form-control" placeholder="Teléfono" />
                <label asp-for="Input.Telefono">Teléfono</label>
                <span asp-validation-for="Input.Telefono" class="text-danger"></span>
            </div>

            <!-- Fecha de nacimiento -->
            <div class="form-floating mb-3">
                <input asp-for="Input.FechaNacimiento" class="form-control" type="date" />
                <label asp-for="Input.FechaNacimiento">Fecha de nacimiento</label>
                <span asp-validation-for="Input.FechaNacimiento" class="text-danger"></span>
            </div>

            <!-- Sexo -->
            <div class="form-floating mb-3">
                <select asp-for="Input.Sexo" class="form-control">
                    <option value="">-- Selecciona --</option>
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Prefiero no decirlo">Prefiero no decirlo</option>
                </select>
                <label asp-for="Input.Sexo">Sexo</label>
                <span asp-validation-for="Input.Sexo" class="text-danger"></span>
            </div>

            <!-- Rol -->
            <div class="form-floating mb-3">
                <select asp-for="Input.Rol" class="form-control">
                    <option value="">-- Selecciona un rol --</option>
                    <option value="Coleccionista">Coleccionista</option>
                    <option value="Perito">Perito</option>
                    <option value="Restaurador">Restaurador</option>
                </select>
                <label asp-for="Input.Rol">Rol</label>
                <span asp-validation-for="Input.Rol" class="text-danger"></span>
            </div>

            <!-- Contraseña -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Contraseña" />
                <label asp-for="Input.Password">Contraseña</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Confirmar contraseña -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirmar contraseña" />
                <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Botón registrarse -->
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">
                Registrarse
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}