@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<style>
    .register-wrapper {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .register-card {
        background: #ffffff;
        border: 1px solid rgba(154,123,62,.18);
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(90,60,20,.1);
        width: 100%;
        max-width: 680px;
        overflow: hidden;
    }

    .register-header {
        background: linear-gradient(135deg, rgba(154,123,62,.08) 0%, rgba(154,123,62,.03) 100%);
        border-bottom: 1px solid rgba(154,123,62,.14);
        padding: 2.2rem 2.5rem 1.8rem;
        text-align: center;
    }

    .register-header .brand-icon {
        width: 48px;
        height: 48px;
        background: var(--gold, #9A7B3E);
        clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
        margin: 0 auto 1rem;
    }

    .register-header h1 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.9rem;
        font-weight: 300;
        color: #5C3D1E;
        margin: 0 0 .3rem;
        letter-spacing: .03em;
    }

    .register-header p {
        color: #8C7055;
        font-size: .85rem;
        margin: 0;
    }

    .register-body {
        padding: 2rem 2.5rem 2.5rem;
    }

    .section-label {
        font-size: .65rem;
        font-weight: 500;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: #9A7B3E;
        margin-bottom: 1rem;
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(154,123,62,.18);
    }

    .section-label:first-of-type {
        margin-top: 0;
    }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fields-grid .full {
        grid-column: 1 / -1;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: .28rem;
    }

    .field-group label {
        font-size: .68rem;
        font-weight: 400;
        letter-spacing: .11em;
        text-transform: uppercase;
        color: #8C7055;
    }

    .field-group .form-control,
    .field-group .form-select {
        background: #FAF6EF;
        border: 1px solid rgba(154,123,62,.2);
        border-radius: 6px;
        color: #3B2A1A;
        padding: .62rem .88rem;
        font-size: .92rem;
        transition: border-color .2s, box-shadow .2s, background .2s;
    }

    .field-group .form-control:focus,
    .field-group .form-select:focus {
        background: #ffffff;
        border-color: #9A7B3E;
        box-shadow: 0 0 0 3px rgba(154,123,62,.1);
        outline: none;
    }

    .field-group .form-select option {
        background: #FAF6EF;
        color: #3B2A1A;
    }

    .field-group .text-danger {
        font-size: .75rem;
        color: #A63D2F !important;
    }

    .validation-summary-errors {
        background: rgba(166,61,47,.06);
        border: 1px solid rgba(166,61,47,.2);
        border-radius: 8px;
        padding: .8rem 1rem;
        margin-bottom: 1.4rem;
        color: #A63D2F;
        font-size: .83rem;
    }

    .btn-register {
        width: 100%;
        background: #9A7B3E;
        border: none;
        border-radius: 8px;
        color: #ffffff;
        font-size: .82rem;
        font-weight: 500;
        letter-spacing: .14em;
        text-transform: uppercase;
        padding: .85rem;
        margin-top: 1.6rem;
        transition: background .2s, box-shadow .2s, transform .15s;
        cursor: pointer;
    }

    .btn-register:hover {
        background: #B8973F;
        box-shadow: 0 4px 18px rgba(154,123,62,.28);
        transform: translateY(-1px);
    }

    .register-footer {
        text-align: center;
        padding: 1.2rem 2.5rem 1.8rem;
        border-top: 1px solid rgba(154,123,62,.1);
        font-size: .83rem;
        color: #8C7055;
    }

    .register-footer a {
        color: #9A7B3E;
        font-weight: 500;
        text-decoration: none;
    }

    .register-footer a:hover {
        color: #B8973F;
        text-decoration: underline;
    }

    @@media (max-width: 560px) {
        .fields-grid { grid-template-columns: 1fr; }
        .register-body { padding: 1.5rem 1.2rem 2rem; }
        .register-header { padding: 1.8rem 1.2rem 1.4rem; }
        .register-footer { padding: 1rem 1.2rem 1.5rem; }
    }
</style>

<div class="register-wrapper">
    <div class="register-card">

        <!-- Encabezado -->
        <div class="register-header">
            <div class="brand-icon"></div>
            <h1>Crear cuenta</h1>
            <p>Completa el formulario para unirte a PGDCP</p>
        </div>

        <div class="register-body">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                <!-- Errores generales -->
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                <!-- Información personal -->
                <div class="section-label">Información personal</div>
                <div class="fields-grid">

                    <div class="field-group">
                        <label asp-for="Input.Nombre">Nombre</label>
                        <input asp-for="Input.Nombre" class="form-control" placeholder="Tu nombre" />
                        <span asp-validation-for="Input.Nombre" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Input.Apellido">Apellido</label>
                        <input asp-for="Input.Apellido" class="form-control" placeholder="Tu apellido" />
                        <span asp-validation-for="Input.Apellido" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Input.FechaNacimiento">Fecha de nacimiento</label>
                        <input asp-for="Input.FechaNacimiento" class="form-control" type="date" />
                        <span asp-validation-for="Input.FechaNacimiento" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Input.Sexo">Sexo</label>
                        <select asp-for="Input.Sexo" class="form-select">
                            <option value="">-- Selecciona --</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                            <option value="Prefiero no decirlo">Prefiero no decirlo</option>
                        </select>
                        <span asp-validation-for="Input.Sexo" class="text-danger"></span>
                    </div>

                </div>

                <!-- Contacto y rol -->
                <div class="section-label">Contacto y rol</div>
                <div class="fields-grid">

                    <div class="field-group">
                        <label asp-for="Input.Email">Correo electrónico</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="nombre@ejemplo.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Input.Telefono">Teléfono</label>
                        <input asp-for="Input.Telefono" class="form-control" placeholder="Tu número" />
                        <span asp-validation-for="Input.Telefono" class="text-danger"></span>
                    </div>

                    <div class="field-group full">
                        <label asp-for="Input.Rol">Rol en el sistema</label>
                        <select asp-for="Input.Rol" class="form-select">
                            <option value="">-- Selecciona un rol --</option>
                            <option value="Coleccionista">Coleccionista</option>
                            <option value="Perito">Perito</option>
                            <option value="Restaurador">Restaurador</option>
                        </select>
                        <span asp-validation-for="Input.Rol" class="text-danger"></span>
                    </div>

                </div>

                <!-- Seguridad -->
                <div class="section-label">Seguridad</div>
                <div class="fields-grid">

                    <div class="field-group">
                        <label asp-for="Input.Password">Contraseña</label>
                        <input asp-for="Input.Password" class="form-control" type="password" autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" placeholder="Repite la contraseña" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                </div>

                <button id="registerSubmit" type="submit" class="btn-register">
                    Crear cuenta
                </button>

            </form>
        </div>

        <div class="register-footer">
            ¿Ya tienes cuenta? <a asp-controller="Login" asp-action="Index">Inicia sesión aquí</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}