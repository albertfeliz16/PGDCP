@page
@model Disable2faModel
@{
    ViewData["Title"] = "Desactivar autenticación de dos factores (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}
<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Esta acción solo desactiva la 2FA.</strong>
    </p>
    <p>
        Desactivar la 2FA no cambia las claves usadas en las aplicaciones de autenticación. Si deseas cambiar la clave
        usada en una aplicación de autenticación, debes <a asp-page="./ResetAuthenticator">restablecer tus claves de autenticación.</a>
    </p>
</div>
<div>
    <form method="post">
        <button class="btn btn-danger" type="submit">Desactivar 2FA</button>
    </form>
</div>