@model IEnumerable<PGDCP.Models.Valoracion>
@{
    ViewData["Title"] = "Valoraciones Periciales";
    var isAdmin = User.IsInRole("Administrador");
}

<div class="page-header">
    <h1>Valoraciones Periciales</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Nueva valoración</a>
</div>

@if (isAdmin)
{
    <div class="role-callout"><span>👑</span><span><strong>Administrador</strong> — puedes ver, editar y eliminar todas las valoraciones del sistema.</span></div>
}
else
{
    <div class="role-callout"><span>⚖</span><span><strong>Perito</strong> — puedes crear y editar valoraciones periciales. Solo el Administrador puede eliminarlas.</span></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">⚖</div>
        <h3>Sin valoraciones registradas</h3>
        <p>Registra peritajes y valoraciones comerciales de las obras de la colección.</p>
        <a asp-action="Create" class="btn btn-primary mt-3">Crear primera valoración</a>
    </div>
}
else
{
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-bar">
                <input type="text" id="tableSearch" placeholder="Buscar por obra, observaciones..." />
                <span class="search-icon">🔍</span>
            </div>
        </div>
        <div class="toolbar-right" style="color:var(--text-muted);font-size:.78rem;">@Model.Count() valoración(es)</div>
    </div>
    <div class="table-wrapper fade-in">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Obra</th>
                        <th>Valor determinado</th>
                        <th>Fecha valoración</th>
                        <th>Perito</th>
                        <th>Observaciones</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.Obra != null) { <span style="font-family:var(--fd);color:var(--ivory);">@item.Obra.Titulo</span> }
                                else { <span class="badge badge-gold">#@item.ObraId</span> }
                            </td>
                            <td><span style="color:var(--gold-light);font-family:var(--fd);font-size:1.05rem;">$@item.ValorEstimado.ToString("N0")</span></td>
                            <td style="color:var(--text-muted);font-size:.82rem;">@item.FechaValoracion.ToString("dd/MM/yyyy")</td>
                            <td style="color:var(--text-muted);font-size:.8rem;">@(item.PeritoId?.Length > 8 ? item.PeritoId[..8] + "..." : item.PeritoId)</td>
                            <td style="color:var(--text-muted);font-size:.82rem;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Observaciones</td>
                            <td>
                                <div class="action-links">
                                    <a class="action-link" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                                    <span class="action-sep">·</span>
                                    <a class="action-link" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                    @if (isAdmin)
                                    {
                                        <span class="action-sep">·</span>
                                        <a class="action-link danger" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
