@model PGDCP.Models.PerfilUsuario
@{
    ViewData["Title"] = "Mi Perfil - Administrador";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3>👑 Perfil de Administrador</h3>
        </div>
        <div class="card-body">
            <h5>Bienvenido, @Model.Nombre @Model.Apellido</h5>
            <hr />
            <p><strong>Teléfono:</strong> @Model.Telefono</p>
            <p><strong>Fecha de nacimiento:</strong> @Model.FechaNacimiento.ToShortDateString()</p>
            <hr />
            <h5>Accesos rápidos</h5>
            <a asp-controller="Obras" asp-action="Index" class="btn btn-primary">
                Ver Obras
            </a>
            <a asp-controller="Conservacions" asp-action="Index" class="btn btn-outline-primary ms-2">
                Ver Conservaciones
            </a>
            <a asp-controller="Valoracions" asp-action="Index" class="btn btn-outline-primary ms-2">
                Ver Valoraciones
            </a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-primary ms-2">
                Panel Admin
            </a>
        </div>
    </div>
</div>