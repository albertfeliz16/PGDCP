@model Conservacion
@{ ViewData["Title"] = "Editar Conservación"; }

<div class="page-header">
    <h1>Editar Registro de Conservación</h1>
    <a asp-action="Index" class="btn btn-sm" style="color:var(--text-muted);">← Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card fade-in">
            <div class="card-header">Editando registro #@Model?.Id</div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="RestauradorId" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="form-group">
                                <label asp-for="ObraId" class="form-label">Obra *</label>
                                <select asp-for="ObraId" class="form-select" asp-items="ViewBag.ObraId">
                                    <option value="">— Seleccione una obra —</option>
                                </select>
                                <span asp-validation-for="ObraId" class="field-validation-error"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="FechaIntervencion" class="form-label">Fecha de Intervención</label>
                                <input asp-for="FechaIntervencion" class="form-control" type="date" />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Diagnostico" class="form-label">Diagnóstico *</label>
                                <textarea asp-for="Diagnostico" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Diagnostico" class="field-validation-error"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-group">
                                <label asp-for="Tratamiento" class="form-label">Tratamiento aplicado</label>
                                <textarea asp-for="Tratamiento" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                    <hr class="divider">
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-light">Cancelar</a>
                        <button type="submit" class="btn btn-primary">Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
