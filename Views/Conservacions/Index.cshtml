@model IEnumerable<Conservacion>
@{
    ViewData["Title"] = "Conservación y Restauración";
    var isAdmin = User.IsInRole("Administrador");
    var isRestaurador = User.IsInRole("Restaurador");
}

<div class="page-header">
    <h1>Conservación y Restauración</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo registro</a>
</div>

@if (isAdmin)
{
    <div class="role-callout"><span>👑</span><span><strong>Administrador</strong> — puedes ver, editar y eliminar todos los registros de conservación.</span></div>
}
else
{
    <div class="role-callout"><span>🔬</span><span><strong>Restaurador</strong> — puedes crear y editar registros de conservación. Solo el Administrador puede eliminarlos.</span></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🔬</div>
        <h3>Sin registros de conservación</h3>
        <p>Registra el estado de conservación y los tratamientos aplicados a las obras.</p>
        <a asp-action="Create" class="btn btn-primary mt-3">Crear primer registro</a>
    </div>
}
else
{
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-bar">
                <input type="text" id="tableSearch" placeholder="Buscar por diagnóstico, tratamiento..." />
                <span class="search-icon">🔍</span>
            </div>
        </div>
        <div class="toolbar-right" style="color:var(--text-muted);font-size:.78rem;">
            @Model.Count() registro(s)
        </div>
    </div>
    <div class="table-wrapper fade-in">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Obra</th>
                        <th>Diagnóstico</th>
                        <th>Tratamiento</th>
                        <th>Fecha intervención</th>
                        <th>Restaurador</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge badge-gold">#@item.ObraId</span></td>
                            <td><span style="color:var(--ivory);">@item.Diagnostico</span></td>
                            <td style="color:var(--text-muted);font-size:.85rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Tratamiento</td>
                            <td style="color:var(--text-muted);font-size:.82rem;">@item.FechaIntervencion.ToString("dd/MM/yyyy")</td>
                            <td style="color:var(--text-muted);font-size:.8rem;">@(item.RestauradorId?.Length > 8 ? item.RestauradorId[..8] + "..." : item.RestauradorId)</td>
                            <td>
                                <div class="action-links">
                                    <a class="action-link" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                                    <span class="action-sep">·</span>
                                    <a class="action-link" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                    @if (isAdmin)
                                    {
                                        <span class="action-sep">·</span>
                                        <a class="action-link danger" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
