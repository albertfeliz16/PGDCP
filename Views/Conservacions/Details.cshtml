@model Conservacion
@{ ViewData["Title"] = "Detalle de Conservación"; }

<div class="page-header">
    <h1>Registro de Conservación</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-light">Editar</a>
        <a asp-action="Index" class="btn btn-sm" style="color:var(--text-muted);">← Volver</a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card fade-in">
            <div class="card-header">Ficha de Intervención #@Model?.Id</div>
            <div class="card-body">
                <div class="detail-grid">
                    <div><div class="detail-label">Obra (ID)</div><div class="detail-value"><span class="badge badge-gold">#@Model?.ObraId</span></div></div>
                    <div><div class="detail-label">Fecha de Intervención</div><div class="detail-value">@Model?.FechaIntervencion.ToString("d MMMM yyyy")</div></div>
                </div>
                <hr class="divider">
                <div class="form-group">
                    <div class="detail-label">Diagnóstico</div>
                    <div style="color:var(--ivory);line-height:1.7;margin-top:.4rem;">@Model?.Diagnostico</div>
                </div>
                <div class="form-group mt-3">
                    <div class="detail-label">Tratamiento aplicado</div>
                    <div style="color:var(--text);line-height:1.7;margin-top:.4rem;">@(Model?.Tratamiento ?? "—")</div>
                </div>
                <hr class="divider">
                <div><div class="detail-label">ID del Restaurador</div><div style="color:var(--text-muted);font-size:.85rem;margin-top:.2rem;">@(Model?.RestauradorId ?? "No registrado")</div></div>
            </div>
        </div>
    </div>
</div>
