@model Obra
@{
    ViewData["Title"] = Model?.Titulo ?? "Detalle de Obra";
    var isAdmin = User.IsInRole("Administrador");
    var isOwner = Model?.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canEdit = isAdmin || isOwner;
}

<div class="page-header">
    <h1>@Model?.Titulo</h1>
    <div class="d-flex gap-2 flex-wrap">
        @if (canEdit) { <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-light">Editar</a> }
        <a asp-action="Index" class="btn btn-sm" style="color:var(--text-muted);">← Volver</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card fade-in">
            <div class="card-header">Ficha Técnica</div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-item">
                        <div class="detail-label">Título</div>
                        <div class="detail-value">@Model?.Titulo</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Autor</div>
                        <div class="detail-value">@Model?.Autor</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Época</div>
                        <div class="detail-value"><span class="badge badge-teal">@Model?.Epoca</span></div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Estilo</div>
                        <div class="detail-value">@Model?.Estilo</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Material</div>
                        <div class="detail-value">@Model?.Material</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Fecha de Adquisición</div>
                        <div class="detail-value">@Model?.FechaAdquisicion.ToString("d MMMM yyyy")</div>
                    </div>
                </div>

                @if (isAdmin || User.IsInRole("Perito"))
                {
                    <hr class="divider">
                    <div class="detail-item">
                        <div class="detail-label">Valor Estimado</div>
                        <div class="detail-value" style="font-size:1.8rem;color:var(--gold-light);">
                            $@Model?.ValorEstimado.ToString("N2")
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model?.ImagenUrl))
                {
                    <hr class="divider">
                    <div class="detail-label">Imagen de referencia</div>
                    <div class="mt-2">
                        <img src="@Model.ImagenUrl" alt="@Model.Titulo"
                             style="max-width:100%;max-height:320px;object-fit:contain;border-radius:var(--r);border:1px solid rgba(201,168,76,.14);" />
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card fade-in" style="animation-delay:.1s;">
            <div class="card-header">Acciones disponibles</div>
            <div class="card-body d-flex flex-column gap-2">
                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary btn-sm w-100">Editar obra</a>
                }
                @if (User.IsInRole("Administrador") || User.IsInRole("Restaurador"))
                {
                    <a asp-controller="Conservacions" asp-action="Create" class="btn btn-teal btn-sm w-100">
                        + Registrar conservación
                    </a>
                }
                @if (User.IsInRole("Administrador") || User.IsInRole("Perito"))
                {
                    <a asp-controller="Valoracions" asp-action="Create" class="btn btn-outline-light btn-sm w-100">
                        + Registrar valoración
                    </a>
                }
                @if (isAdmin)
                {
                    <hr class="divider" style="margin:.4rem 0;">
                    <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger btn-sm w-100">Eliminar obra</a>
                }
                @if (!canEdit && !User.IsInRole("Restaurador") && !User.IsInRole("Perito"))
                {
                    <p style="color:var(--text-muted);font-size:.8rem;text-align:center;margin-top:.5rem;">
                        Solo el propietario o el Administrador pueden editar esta obra.
                    </p>
                }
            </div>
        </div>
    </div>
</div>
